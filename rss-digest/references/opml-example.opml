<?xml version="1.0" encoding="UTF-8"?>
<opml version="2.0">
  <head>
    <title>My RSS Feeds</title>
    <dateCreated>Thu, 01 Jan 2025 00:00:00 GMT</dateCreated>
  </head>
  <body>
    <!-- Feeds can be flat or organized into category folders -->

    <!-- Flat feed (no category) -->
    <outline type="rss" text="Hacker News" title="Hacker News"
             xmlUrl="https://news.ycombinator.com/rss"
             htmlUrl="https://news.ycombinator.com"/>

    <!-- Category folder with nested feeds -->
    <outline text="Tech News" title="Tech News">
      <outline type="rss" text="The Verge" title="The Verge"
               xmlUrl="https://www.theverge.com/rss/index.xml"
               htmlUrl="https://www.theverge.com"/>
      <outline type="rss" text="Ars Technica" title="Ars Technica"
               xmlUrl="https://feeds.arstechnica.com/arstechnica/index"
               htmlUrl="https://arstechnica.com"/>
      <outline type="rss" text="TechCrunch" title="TechCrunch"
               xmlUrl="https://techcrunch.com/feed/"
               htmlUrl="https://techcrunch.com"/>
    </outline>

    <outline text="AI &amp; Machine Learning" title="AI &amp; Machine Learning">
      <outline type="rss" text="MIT Technology Review - AI" title="MIT Technology Review - AI"
               xmlUrl="https://www.technologyreview.com/feed/"
               htmlUrl="https://www.technologyreview.com"/>
      <outline type="rss" text="Import AI (Jack Clark)" title="Import AI (Jack Clark)"
               xmlUrl="https://jack-clark.net/feed/"
               htmlUrl="https://jack-clark.net"/>
    </outline>

    <outline text="Business &amp; Startups" title="Business &amp; Startups">
      <outline type="rss" text="Paul Graham Essays" title="Paul Graham Essays"
               xmlUrl="http://www.paulgraham.com/rss.html"
               htmlUrl="http://www.paulgraham.com"/>
      <outline type="rss" text="a16z Blog" title="a16z Blog"
               xmlUrl="https://a16z.com/feed/"
               htmlUrl="https://a16z.com"/>
    </outline>
  </body>
</opml>
